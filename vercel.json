{
  "redirects": [
    {
      "source": "/allnet-landing.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/org",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/org/",
      "destination": "/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/apple-app-site-association",
      "destination": "/api/apple-app-site-association"
    },
    {
      "source": "/.well-known/assetlinks.json",
      "destination": "/api/assetlinks"
    },
    {
      "source": "/auth-callback",
      "destination": "/auth-callback.html"
    },
    {
      "source": "/r/:org/:code",
      "destination": "/api/session?org=:org&code=:code"
    },
    {
      "source": "/p/:slug",
      "destination": "/api/player?slug=:slug"
    },
    {
      "source": "/org/:slug",
      "destination": "/api/org?slug=:slug"
    },
    {
      "source": "/dashboard",
      "destination": "/allnet-dashboard.html"
    },
    {
      "source": "/courts/:slug",
      "destination": "/api/court?slug=:slug"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    }
  ]
}
