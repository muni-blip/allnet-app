{
	"appId": "com.allnetgames.app",
	"appName": "AllNet",
	"webDir": "www",
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": false,
			"backgroundColor": "#0A0A0A",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#000000"
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		}
	},
	"ios": {
		"scheme": "AllNet",
		"contentInset": "always"
	},
	"android": {
		"allowMixedContent": true
	}
}
